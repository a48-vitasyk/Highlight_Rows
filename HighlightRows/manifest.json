{
  "manifest_version": 3,
  "name": "Highlight Rows",
  "version": "3.90.0",
  "description": "Ticket helper for the Zomro panel: highlight by blocked request and subject tags, manual time reminders, a 'no support reply > N h' monitor, and client traffic in the ticket.",
  "key": "",
  "permissions": [
    "storage",
    "notifications",
    "identity",
    "sidePanel",
    "alarms"
  ],
  "host_permissions": [
    "https://*.supabase.co/*",
    "wss://*.supabase.co/*",
    "https://translate.googleapis.com/*"
  ],
  "side_panel": {
    "default_path": "popup.html?view=panel"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.zomro.com/*",
        "*://*.omro.host/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["beep.wav", "sounds/*.wav"],
      "matches": [
        "*://*.zomro.com/*",
        "*://*.omro.host/*"
      ]
    }
  ]
}
